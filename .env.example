# Safety switches — read docs/DISCLAIMER.md before changing these.
ENABLE_LIVE_TRADING=false
KILL_SWITCH=false

# Execution mode helpers
# simulated = in-process fills only (default, recommended for learning)
# paper/live = requires IBKR TWS or Gateway; see docs/IBKR_SETUP.md
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_USE_REAL=false

# AWS Secrets Manager (optional) — see docs/AWS_SETUP.md
AWS_SECRETS_ENABLED=false
AWS_REGION=us-east-1
AWS_SECRETS_NAME=hedge-fund-at-home/dev
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

LOG_LEVEL=INFO
HFAH_CONFIG=config/config.yaml
