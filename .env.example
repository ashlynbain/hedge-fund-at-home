# Safety switches — read docs/DISCLAIMER.md before changing these.
ENABLE_LIVE_TRADING=false
KILL_SWITCH=false

# ---------------------------------------------------------------------------
# Your broker (pick one path)
# ---------------------------------------------------------------------------
# simulated  — default; no connection (mode: simulated in config.yaml)
# ibkr       — Interactive Brokers via TWS/Gateway (adapter included)
# custom     — your paper API: set BROKER_CUSTOM_MODULE (see hedgekit/broker/)
BROKER_ADAPTER=simulated
# BROKER_CUSTOM_MODULE=my_brokers.alpaca:MyPaperBroker

# IBKR (when BROKER_ADAPTER=ibkr or mode: paper with IBKR)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_USE_REAL=false

# Placeholder keys for other brokers (not used until you implement custom_broker)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# TRADIER_ACCESS_TOKEN=
# TRADIER_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Your cloud secrets (optional — pick one provider)
# ---------------------------------------------------------------------------
# CLOUD_PROVIDER=none
# AWS (included Terraform under infrastructure/aws/)
AWS_SECRETS_ENABLED=false
AWS_REGION=us-east-1
AWS_SECRETS_NAME=hedge-fund-at-home/dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# GCP placeholder — use Secret Manager → inject same keys as env at runtime
# GCP_PROJECT_ID=
# GCP_SECRET_NAME=hfah-env

# Azure placeholder — Key Vault → Container Apps / VM env
# AZURE_KEY_VAULT_NAME=
# AZURE_SECRET_NAME=hfah-env

# ---------------------------------------------------------------------------
# Data — default is Yahoo via yfinance (no keys). Override in marketdata.py for your feed.
# ---------------------------------------------------------------------------
# DATA_PROVIDER=yfinance

LOG_LEVEL=INFO
HFAH_CONFIG=config/config.yaml
